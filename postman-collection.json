    {
      "name": "Finance",
      "item": [
        {
          "name": "Create Finance Record",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 5000,\n  \"type\": \"income\",\n  \"category\": \"salary\",\n  \"date\": \"2026-04-01\",\n  \"notes\": \"Monthly salary\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/finance",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "finance"
              ]
            }
          }
        },
        {
          "name": "Get Finance Records",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{viewerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/finance?type=income&category=salary&fromDate=2026-04-01&toDate=2026-04-30",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "finance"
              ],
              "query": [
                {
                  "key": "type",
                  "value": "income"
                },
                {
                  "key": "category",
                  "value": "salary"
                },
                {
                  "key": "fromDate",
                  "value": "2026-04-01"
                },
                {
                  "key": "toDate",
                  "value": "2026-04-30"
                }
              ]
            }
          }
        },
        {
          "name": "Get Single Finance Record",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{viewerAccessToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/finance/{{financeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "finance",
                "{{financeId}}"
              ]
            }
          }
        },
        {
          "name": "Update Finance Record",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
