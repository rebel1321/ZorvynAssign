            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Viewer User\",\n  \"email\": \"{{viewerEmail}}\",\n  \"password\": \"{{viewerPassword}}\",\n  \"role\": \"viewer\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
