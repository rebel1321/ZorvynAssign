            "body": {
              "mode": "raw",
              "raw": "{\n  \"amount\": 6500,\n  \"type\": \"income\",\n  \"category\": \"salary\",\n  \"date\": \"2026-04-01\",\n  \"notes\": \"Updated salary amount\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/finance/{{financeId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "finance",
                "{{financeId}}"
              ]
            }
          }
        },
        {
          "name": "Delete Finance Record",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminAccessToken}}"
